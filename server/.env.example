# ==================== 阿里云百炼配置 ====================
# 从阿里云百炼控制台获取：https://bailian.console.aliyun.com/
# 步骤：开通百炼服务 → API-KEY 管理 → 创建新的 API-KEY
DASHSCOPE_API_KEY=sk-xxx

# ==================== 模型选择 ====================
# Qwen 模型选项：qwen-max, qwen-plus, qwen-turbo
# 推荐：qwen-plus（性价比高）
LLM_MODEL=qwen-plus

# ==================== 实时 ASR 配置 ====================
# 阿里云百炼实时语音识别模型
ASR_MODEL=qwen3-asr-flash-realtime

# WebSocket 接入点：
# - 中国内地（北京）：wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# - 国际（新加坡）：wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# ==================== 服务端配置 ====================
PORT=3000
NODE_ENV=development

# ==================== HTTPS 配置 ====================
# 启用 HTTPS（true/false）
USE_HTTPS=false

# HTTPS 端口
HTTPS_PORT=3443

# SSL 证书路径（可选，留空则自动生成自签名证书）
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# ==================== WebSocket 配置 ====================
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000

# ==================== 火山云 RTC（可选） ====================
# 如需数字人视频功能，配置以下凭证
# 否则可留空，使用纯语音 + 文字模式
VOLC_APP_ID=your_app_id_here
VOLC_APP_KEY=your_app_key_here
