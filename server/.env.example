# ==================== AI 模式配置 ====================
# 选择 AI 对话模式（3 选 1）:
# - custom: 使用真实 LLM (OpenAI/Claude/Gemini/Ollama) ⭐ 推荐
# - s2s: 火山引擎端到端语音大模型
# - component: 火山引擎分组件模式 (ASR+LLM+TTS)

AI_MODE=custom


# ==================== 真实 LLM 配置 (AI_MODE=custom 时使用) ====================
# 文档：https://github.com/badlogic/pi-mono/tree/main/packages/ai

# LLM 提供商选择:
# - openai: OpenAI GPT 系列 (gpt-4o, gpt-4o-mini, gpt-3.5-turbo)
# - anthropic: Anthropic Claude 系列 (claude-sonnet-4-20250514, claude-haiku-3-5)
# - google: Google Gemini 系列 (gemini-2.0-flash, gemini-pro)
# - ollama: 本地 Ollama (无需 API Key，需设置 LLM_BASE_URL)
# - openrouter: OpenRouter 多模型平台

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API Key 获取:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/
# - Google: https://makersuite.google.com/app/apikey
# - OpenRouter: https://openrouter.ai/keys
# - Ollama: 不需要 API Key

LLM_API_KEY=sk-proj-your-api-key-here

# 自定义 API 地址（可选）:
# - Ollama: http://localhost:11434/v1
# - 其他兼容 OpenAI API 的服务
# LLM_BASE_URL=http://localhost:11434/v1


# ==================== 火山引擎配置 (AI_MODE=s2s/component 时使用) ====================
# 获取：https://console.volcengine.com/rtc

VOLC_APP_ID=your-volc-app-id
VOLC_APP_KEY=your-volc-app-key

# API 凭证
# 获取：https://console.volcengine.com/iam/keymanage
VOLC_ACCESS_KEY=your-access-key
VOLC_SECRET_KEY=your-secret-key

# ASR 配置（分组件模式需要）
VOLC_ASR_APP_ID=
VOLC_ASR_TOKEN=
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# TTS 配置（分组件模式需要）
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
VOLC_TTS_RESOURCE_ID=volc.service_type.10029
VOLC_TTS_VOICE_TYPE=zh_female_linjianvhai_moon_bigtts

# S2S 配置（端到端模式需要）
# 获取：https://console.volcengine.com/ark
VOLC_S2S_APP_ID=
VOLC_S2S_TOKEN=
VOLC_S2S_MODEL_VERSION=O
VOLC_S2S_OUTPUT_MODE=0


# ==================== 服务配置 ====================

# 服务端口
PORT=3000

# HTTPS 配置（生产环境推荐启用）
USE_HTTPS=false
HTTPS_PORT=3443
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem


# ==================== pi-agent 配置 (AI_MODE=custom 时使用) ====================

# pi-agent API Key（内部使用，保护服务不被未授权访问）
PI_AGENT_API_KEY=pi-agent-secret-key-change-in-production

# 温度参数 (0.1-1.0，越高越随机)
PI_AGENT_TEMPERATURE=0.7

# 最大 token 数
PI_AGENT_MAX_TOKENS=500

# Top-P 参数
PI_AGENT_TOP_P=0.9

# 历史对话轮数（保留最近 N 轮）
PI_AGENT_HISTORY_LENGTH=3


# ==================== 认证配置 ====================

# JWT 密钥（生产环境请使用强随机字符串）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production


# ==================== 日志配置 ====================

# 日志级别：debug, info, warn, error
LOG_LEVEL=info


# ==================== 其他配置 ====================

# 环境变量
NODE_ENV=development

# 超时配置（秒）
REQUEST_TIMEOUT=30

# 最大并发连接数
MAX_CONNECTIONS=100


# ==================== 快速配置示例 ====================

# 示例 1: 使用 OpenAI GPT-4o Mini（推荐）
# AI_MODE=custom
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-proj-xxx

# 示例 2: 使用 Anthropic Claude
# AI_MODE=custom
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-api03-xxx

# 示例 3: 使用本地 Ollama（免费）
# AI_MODE=custom
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1

# 示例 4: 使用火山引擎端到端
# AI_MODE=s2s
# VOLC_APP_ID=xxx
# VOLC_APP_KEY=xxx
# VOLC_S2S_APP_ID=xxx
# VOLC_S2S_TOKEN=xxx

# 示例 5: 使用火山引擎分组件
# AI_MODE=component
# VOLC_APP_ID=xxx
# VOLC_APP_KEY=xxx
# VOLC_ASR_APP_ID=xxx
# VOLC_ASR_TOKEN=xxx
# VOLC_TTS_APP_ID=xxx
# VOLC_TTS_TOKEN=xxx
