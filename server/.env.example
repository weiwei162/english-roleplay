# ==================== 火山云 RTC 配置 ====================
# 获取地址：https://console.volcengine.com/rtc
VOLC_APP_ID=你的 RTC 应用 ID

# ⭐ OpenAPI 访问密钥（不是 AppKey！）
# 获取地址：https://console.volcengine.com/iam/keymanage/
VOLC_ACCESS_KEY=你的 AccessKey
VOLC_SECRET_KEY=你的 SecretKey

# ==================== 阿里云百炼配置 ====================
DASHSCOPE_API_KEY=sk-你的密钥

# ==================== 模型选择 ====================
LLM_MODEL=qwen-plus
ASR_MODEL=qwen3-asr-flash-realtime
ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# ==================== 服务端配置 ====================
PORT=3000
USE_HTTPS=false
