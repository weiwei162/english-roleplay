# ==================== AI 模式配置 ====================
# 选择 AI 对话模式（3 选 1）:
# - custom: 使用真实 LLM (OpenAI/Claude/Gemini/Ollama) ⭐ 推荐
# - s2s: 火山引擎端到端语音大模型
# - component: 火山引擎分组件模式 (ASR+LLM+TTS)

AI_MODE=custom


# ==================== 真实 LLM 配置 (AI_MODE=custom 时使用) ====================

# LLM 提供商选择:
# - openai: OpenAI GPT 系列 (gpt-4o, gpt-4o-mini)
# - anthropic: Anthropic Claude 系列 (claude-sonnet-4-20250514)
# - google: Google Gemini 系列 (gemini-2.0-flash)
# - ollama: 本地 Ollama (无需 API Key)

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-proj-your-api-key-here

# 自定义 API 地址（可选）
# - Ollama: http://localhost:11434/v1
# - Kimi: https://api.moonshot.cn/v1
# - 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_BASE_URL=

# pi-agent 服务地址（可选，默认内置）
# PI_AGENT_URL=http://localhost:3001

# pi-agent 功能开关（JSON 格式，可选）
# PI_AGENT_FEATURE={"enableTools":true}


# ==================== 火山引擎配置 (AI_MODE=s2s/component 时使用) ====================

# RTC 配置
# 获取: https://console.volcengine.com/rtc
VOLC_APP_ID=your-volc-app-id
VOLC_APP_KEY=your-volc-app-key

# API 凭证
# 获取: https://console.volcengine.com/iam/keymanage
VOLC_ACCESS_KEY=your-access-key
VOLC_SECRET_KEY=your-secret-key

# ASR 配置（分组件模式需要）
VOLC_ASR_APP_ID=
VOLC_ASR_TOKEN=
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# TTS 配置（分组件模式需要）
VOLC_TTS_APP_ID=
VOLC_TTS_TOKEN=
VOLC_TTS_RESOURCE_ID=volc.service_type.10029

# LLM 配置（分组件模式需要）
VOLC_LLM_ENDPOINT_ID=

# S2S 配置（端到端模式需要）
# 获取: https://console.volcengine.com/ark
VOLC_S2S_APP_ID=
VOLC_S2S_TOKEN=


# ==================== 服务配置 ====================

PORT=3000

# HTTPS 配置
USE_HTTPS=false
HTTPS_PORT=3443
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem


# ==================== pi-agent 配置 ====================

PI_AGENT_API_KEY=pi-agent-secret-key-change-in-production


# ==================== 认证配置 ====================

# JWT 密钥（生产环境必须修改！）
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production


# ==================== Unsplash 图片配置 ====================
# 获取: https://unsplash.com/developers

UNSPLASH_ACCESS_KEY=your-unsplash-access-key
UNSPLASH_API_URL=https://api.unsplash.com


# ==================== 快速配置示例 ====================

# 示例 1: OpenAI GPT-4o Mini（推荐）
# AI_MODE=custom
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-proj-xxx

# 示例 2: 本地 Ollama（免费）
# AI_MODE=custom
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1

# 示例 3: 火山引擎端到端
# AI_MODE=s2s
# VOLC_APP_ID=xxx
# VOLC_APP_KEY=xxx
# VOLC_S2S_APP_ID=xxx
# VOLC_S2S_TOKEN=xxx

# 示例 4: 火山引擎分组件
# AI_MODE=component
# VOLC_APP_ID=xxx
# VOLC_APP_KEY=xxx
# VOLC_ASR_APP_ID=xxx
# VOLC_ASR_TOKEN=xxx
# VOLC_TTS_APP_ID=xxx
# VOLC_TTS_TOKEN=xxx
# VOLC_LLM_ENDPOINT_ID=xxx