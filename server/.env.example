# ==================== 火山云 RTC 配置 ====================
# 从火山引擎控制台获取：https://console.volcengine.com/rtc
# 步骤：开通 RTC 服务 → 创建应用 → 应用管理 → 查看凭证
VOLC_APP_ID=your_app_id_here
VOLC_APP_KEY=your_app_key_here

# ==================== 豆包大模型 API 配置 ====================
# 从火山引擎方舟控制台获取：https://console.volcengine.com/ark
# 步骤：模型广场 → 豆包 Pro → 开通 → 密钥管理 → 创建密钥
DOUBAO_API_KEY=your_doubao_api_key_here

# ==================== 语音识别 ASR 配置 ====================
# 从火山引擎语音服务控制台获取：https://console.volcengine.com/speech
# 步骤：开通语音识别 → 访问凭证 → 创建密钥
VOLC_ASR_ACCESS_KEY=your_asr_access_key_here
VOLC_ASR_SECRET_KEY=your_asr_secret_key_here

# ==================== 数字人 API（可选） ====================
# 火山引擎智创数字人：https://console.volcengine.com/digital-human
# 或使用第三方服务（D-ID、SadTalker 等）
DIGITAL_HUMAN_API_KEY=your_digital_human_key_here

# ==================== 服务端配置 ====================
PORT=3000
NODE_ENV=development

# ==================== HTTPS 配置 ====================
# 启用 HTTPS（true/false）
USE_HTTPS=false

# HTTPS 端口
HTTPS_PORT=3443

# SSL 证书路径（可选，留空则自动生成自签名证书）
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# ==================== WebSocket 配置 ====================
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=1000
