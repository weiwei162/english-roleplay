# ==================== AI 模式 ====================
# s2s = 端到端模式 (推荐)
# component = 分组件模式 (ASR+LLM+TTS 分别配置)
# custom = 第三方 LLM 模式 (pi-agent-core)
AI_MODE=s2s

# ==================== RTC 配置 ====================
# 火山引擎 RTC 应用凭证
# 获取：https://console.volcengine.com/rtc
VOLC_APP_ID=your_app_id
VOLC_APP_KEY=your_app_key

# ==================== API 凭证 ====================
# 火山引擎 AccessKey 和 SecretKey
# 获取：https://console.volcengine.com/iam/keymanage
VOLC_ACCESS_KEY=your_access_key
VOLC_SECRET_KEY=your_secret_key

# ==================== S2S 配置 ====================
# 豆包端到端语音大模型配置
# 获取：https://console.volcengine.com/ark
VOLC_S2S_APP_ID=your_s2s_app_id
VOLC_S2S_TOKEN=your_s2s_token

# ==================== pi-agent-core 配置 ====================
# 第三方 LLM 模式（AI_MODE=custom 时使用）
# pi-agent-core 服务地址
PI_AGENT_URL=http://localhost:3001/v1/chat/completions
# API Key 鉴权
PI_AGENT_API_KEY=pi-agent-secret-key
# 模型名称
PI_AGENT_MODEL=pi-agent-v1
# 温度参数 (0.1-1.0)
PI_AGENT_TEMPERATURE=0.7
# 最大 token 数
PI_AGENT_MAX_TOKENS=500
# Top-P 参数
PI_AGENT_TOP_P=0.9
# 历史对话轮数
PI_AGENT_HISTORY_LENGTH=3

# ==================== 服务端配置 ====================
PORT=3000

# ==================== 可选配置 ====================
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# S2S 模型版本：O (默认), 或其他支持的版本
VOLC_S2S_MODEL_VERSION=O

# S2S 输出模式：0=纯端到端，1=混合编排
VOLC_S2S_OUTPUT_MODE=0

# ==================== HTTPS 配置 ====================
# 是否启用 HTTPS（生产环境推荐启用）
USE_HTTPS=false

# HTTPS 端口
HTTPS_PORT=3443

# SSL 证书路径
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# ==================== 认证配置 ====================
# JWT 密钥（生产环境请使用强随机字符串）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production
