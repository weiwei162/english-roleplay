# ==================== 火山引擎 StartVoiceChat 配置 ====================
# 文档：https://www.volcengine.com/docs/6348/1558163

# --- RTC 基础配置 ---
# 获取地址：https://console.volcengine.com/rtc/aigc/listRTC
# ⚠️ 注意：使用"实时对话式 AI"应用的 AppId，不是"AI 音视频互动"的
VOLC_APP_ID=你的 RTC AppId
VOLC_APP_KEY=你的 RTC AppKey

# OpenAPI 访问密钥（用于调用 StartVoiceChat API）
# 获取地址：https://console.volcengine.com/iam/keymanage/
VOLC_ACCESS_KEY=你的 AccessKey
VOLC_SECRET_KEY=你的 SecretKey

# --- AI 模式选择 ---
# component: 分组件模式（ASR + LLM + TTS 分别配置）
# s2s: 端到端模式（豆包端到端实时语音大模型）
AI_MODE=s2s

# ==================== 分组件模式配置 (AI_MODE=component 时必需) ====================

# --- ASR 配置 ---
# 获取地址：https://console.volcengine.com/speech/service/10011
VOLC_ASR_APP_ID=你的 ASR AppId
VOLC_ASR_TOKEN=你的 ASR Token
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# 可选：volc.bigasr.sauc.concurrent (1.0 并发版)
#       volc.seedasr.sauc.duration (2.0 小时版)
#       volc.seedasr.sauc.concurrent (2.0 并发版)

# --- LLM 配置 ---
# 获取地址：https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
VOLC_LLM_ENDPOINT_ID=你的方舟推理接入点 ID

# --- TTS 配置 ---
# 获取地址：https://console.volcengine.com/speech/service/10011
VOLC_TTS_APP_ID=你的 TTS AppId
VOLC_TTS_TOKEN=你的 TTS Token
VOLC_TTS_RESOURCE_ID=volc.service_type.10029
# 可选：volc.service_type.10048 (1.0 并发版)
#       seed-tts-2.0 (2.0 字符版)

# ==================== 端到端模式配置 (AI_MODE=s2s 时必需) ====================

# --- S2S 豆包端到端语音大模型 ---
# 获取地址：https://console.volcengine.com/speech/service/10017
VOLC_S2S_APP_ID=你的 S2S AppId
VOLC_S2S_TOKEN=你的 S2S Token

# 模型版本：O / SC / 1.2.1.0 / 2.2.0.0
VOLC_S2S_MODEL_VERSION=O

# 输出模式：0=纯端到端，1=混合编排（端到端 +LLM）
VOLC_S2S_OUTPUT_MODE=0

# 音色（根据模型版本选择）
# O 系列：zh_female_vv_jupiter_bigtts / zh_female_xiaohe_jupiter_bigtts / zh_male_yunzhou_jupiter_bigtts / zh_male_xiaotian_jupiter_bigtts
# SC 系列：参考文档 https://www.volcengine.com/docs/6561/1594356
VOLC_S2S_SPEAKER=zh_female_vv_jupiter_bigtts

# ==================== 可选：阿里云百炼（备用方案） ====================

DASHSCOPE_API_KEY=sk-你的密钥
LLM_MODEL=qwen-plus
ASR_MODEL=qwen3-asr-flash-realtime

# ==================== 服务端配置 ====================

PORT=3000
USE_HTTPS=false
HTTPS_PORT=3443
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# 公网 URL（用于回调）
PUBLIC_URL=http://localhost:3000

# ==================== 配置说明 ====================

# 分组件模式需要开通的服务：
# 1. 实时对话式 AI（RTC 控制台）
# 2. 豆包语音 - 流式语音识别大模型
# 3. 火山方舟 - 大模型推理
# 4. 豆包语音 - 语音合成大模型

# 端到端模式需要开通的服务：
# 1. 实时对话式 AI（RTC 控制台）
# 2. 豆包端到端实时语音大模型

# 快速开始（端到端模式）：
# 1. 设置 AI_MODE=s2s
# 2. 配置 VOLC_APP_ID, VOLC_APP_KEY
# 3. 配置 VOLC_ACCESS_KEY, VOLC_SECRET_KEY
# 4. 配置 VOLC_S2S_APP_ID, VOLC_S2S_TOKEN
# 5. 运行：node index-start-voicechat.js
